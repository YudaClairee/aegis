# SafeHer Mobile Env Variables Example
# Duplicate this file as '.env' in this directory and populate with actual credentials.

# The reachable API endpoint URL. 
# - Use http://localhost:3000 for local development (if using iOS Simulator)
# - Use http://10.0.2.2:3000 for Android Emulator
# - Use ngrok / cloudflared tunnels if testing on a physical device on the same network
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase Credentials (must match the credentials used by the backend API)
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
